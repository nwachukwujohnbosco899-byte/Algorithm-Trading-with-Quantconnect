class CalmBlueAlpaca(QCAlgorithm):

    def initialize(self):
        self.set_start_date(2020, 1, 1)
        self.set_end_date(2021,1,1)
        self.set_cash(100000)
        self.ko= self.add_equity("KO", Resolution.DAILY)
        self.invest= True
        
    def on_data(self, data):
        if not self.portfolio.invested and self.invest:
            self.set_holdings("KO", 0.5)
            self.invested_time= self.time


        self.log(self.Time - self.invested_time)
        time_diff= (self.time- self.invested_time).days
        if time_diff > 100:
            self.liquidate("KO")
            self.invest= False
           
